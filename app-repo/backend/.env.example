PORT=4000
NODE_ENV=development

# Default is for running backend directly on your machine (without compose):
MONGO_URI=mongodb://127.0.0.1:27017/aitask
REDIS_URL=redis://127.0.0.1:6379

# If running via docker-compose (inside containers), these are used:
# MONGO_URI=mongodb://mongo:27017/aitask
# REDIS_URL=redis://redis:6379

JWT_SECRET=replace-me
JWT_EXPIRES_IN=7d

REDIS_STREAM_KEY=ai_tasks

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
